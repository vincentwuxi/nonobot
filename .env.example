# ====================================
# NonoBot Environment Configuration
# ====================================
# Copy this file to .env and fill in your values.
# docker-compose will automatically load .env.

# ─── Core ───
# Gateway port (default: 18790)
NONOBOT_PORT=18790

# Gateway host binding
NONOBOT_HOST=0.0.0.0

# ─── LLM Provider ───
# Uncomment and set ONE of these:

# OpenRouter (recommended starter)
# OPENROUTER_API_KEY=sk-or-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...

# DeepSeek
# DEEPSEEK_API_KEY=sk-...

# ─── Database ───
# Default: SQLite in ~/.nanobot/nonobot.db (no config needed)
# For PostgreSQL (production):
# DATABASE_URL=postgresql://nonobot:password@postgres:5432/nonobot

# ─── Security ───
# JWT secret (auto-generated if not set)
# JWT_SECRET=your-super-secret-key-here

# ─── Optional: Nginx Reverse Proxy ───
# NGINX_PORT=443
# SSL_CERT_PATH=./docker/certs/fullchain.pem
# SSL_KEY_PATH=./docker/certs/privkey.pem
